{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GetHousesResponse",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "name",
      "houseColours",
      "founder",
      "animal",
      "element",
      "ghost",
      "commonRoom",
      "heads",
      "traits"
    ],
    "properties": {
      "id": { "type": "string", "format": "uuid" },
      "name": { "type": "string", "minLength": 1 },
      "houseColours": { "type": "string" },
      "founder": { "type": "string" },
      "animal": { "type": "string" },
      "element": { "type": "string" },
      "ghost": { "type": "string" },
      "commonRoom": { "type": "string" },
      "heads": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "firstName", "lastName"],
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "firstName": { "type": "string" },
            "lastName": { "type": "string" }
          }
        }
      },
      "traits": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name"],
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "name": { "type": "string" }
          }
        }
      }
    }
  }
}